# Copy this file to .env and fill in your API keys

# OpenAI API Key (used for outline + section content generation)
OPENAI_API_KEY=sk-...

# Google Gemini API Key (used for image generation)
GEMINI_API_KEY=AIza...

# Optional: model overrides
OPENAI_MODEL=gpt-4o
GEMINI_IMAGE_MODEL=imagen-3.0-generate-002
